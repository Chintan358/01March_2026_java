package collection;

import java.util.ArrayList;

public class C002_Arraylist {
	public static void main(String[] args) {
		
		
		ArrayList<Integer> al = new ArrayList<Integer>();
		al.add(10);
		al.add(20);
		al.add(30);
		
		
		ArrayList<Integer> al1 = new ArrayList<Integer>(al);
		al1.add(100);
		al1.add(200);
		al1.add(300);
		al1.addAll(al);
		al1.removeAll(al);
		
		for(int i : al1)
		{
			System.out.println(i);
		}
		
		
		
		
	}
}
