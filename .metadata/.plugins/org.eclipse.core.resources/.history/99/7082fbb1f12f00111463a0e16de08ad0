package oops;

//parent - super - base
class A
{
	int a = 10;
	public void display()
	{
		System.out.println("Class A display calling");
	}
}

//child - sub -derived
class B extends A
{
	public void test()
	{
		System.out.println(a);
		System.out.println("class B test calling");
	}
}

public class O006_Inheritance {
	public static void main(String[] args) {
		
		B b = new B();
		b.test();
		//b.display();
		
	}
}
