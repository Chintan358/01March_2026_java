package oops;

class Pen
{
	String color;
	static String company;
	int price;
	
	public void toWrite()
	{
		System.out.println(color+" "+company+" "+price);
	}
	
	static public void display()
	{
		System.out.println("Runing display");
	}
}

public class O001_ClassDemo 
{
	public static void main(String[] args)
	{
		Pen.company = "SS";
		
		Pen p1 = new Pen();
		p1.price =100;
		p1.color="REd";
//		p1.company="Cello";
		p1.toWrite();
		Pen.company = "Cello";
		Pen p2 = new Pen();
		p2.price=500;
		p2.color="Yellow";
		p2.toWrite();
		
		Pen.display();
	}
}
