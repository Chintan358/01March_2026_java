package oops;

class A
{
	int a = 10;
	public void display()
	{
		System.out.println("Class A display calling");
	}
}

class B
{
	public void test()
	{
		System.out.println("class B test calling");
	}
}

public class O006_Inheritance {
	public static void main(String[] args) {
		
		B b = new B();
		b.test();
		
	}
}
