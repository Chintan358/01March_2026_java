package oops;

class P
{
	P()
	{
		System.out.println("P constructor calling");
	}
}

class Q extends P
{
	Q()
	{
		super();
		System.out.println("Q constructor calling");
	}
	
	Q(int i)
	{
		System.out.println("i : "+i);
	}
}

class R extends Q
{
	R()
	{
		super();
		System.out.println("R construcotr calling");
	}
}

public class O007_constructorChaining {
	public static void main(String[] args) {
		
		R r  =new R();
		
	}
}
