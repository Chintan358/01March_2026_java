package oops;

class Maths
{
	public void add(int a, int b)
	{
		System.out.println("Addtion is : "+(a+b));
	}
	
	public void add(int a, int b, int c)
	{
		System.out.println("Addtion is : "+(a+b+c));
	}
	
}

public class O009_MethodOverloading {
	public static void main(String[] args) {
		
		Maths m = new Maths();
		m.add(10, 20);
		m.add(10,20, 30);
	}
}
