package logical;

public class HTD {
	public static void main(String[] args) {
		
		
		String num = "9B";
		for(int i=num.length()-1;i>=0;i--)
		{
			char ch = num.charAt(i);
			if(Character.isAlphabetic(ch))
			{
				int k = ch;
				System.out.println(k);
			}
			else
			{
				int c = ch;
				System.out.println(c);
			}
			
		}
		
	}
}
