package array;

public class A006_MultiDimnetion {
	public static void main(String[] args) {
		
		
		int a[][] = new int[3][3];
		
		a[0][0] = 20;
		a[0][1] = 40;
		a[0][2] = 60;
		
		a[1][0] = 20;
		a[1][1] = 40;
		a[1][2] = 60;
		
		a[2][0] = 20;
		a[2][1] = 40;
		a[2][2] = 60;
		
		for(int i=0;i<3;i++)
		{
			for(int j=0;j<3;j++)
			{
				System.out.println(i+":"+j);
			}
		}
		
		
	}
}
