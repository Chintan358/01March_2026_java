package pattern;

public class P5 {
	public static void main(String[] args) {
		
		
		
//		    *
//		   **
//		  ***
//		 ****
//		*****
		
		int lines = 5;
		for(int j=1;j<=lines;j++)
		{
			for(int k=1;k<=lines-j;k++)
			{
				System.out.print(" ");
			}
			
			for(int i=1;i<=j;i++)
			{
				System.out.print("*");
			}
			System.out.println();
		}
		
	}
}
