package oops;

class Calc
{
	public void message()
	{
		System.out.println("message calling");
	}
	
	public void square(int a)
	{
		int sq = a*a;
		System.out.println(sq);
	}
}

public class O004_MethodManipulation {
	public static void main(String[] args) {
		
		Calc c = new Calc();
		c.message();
		c.square(10);
		c.square(50);
	}
}
