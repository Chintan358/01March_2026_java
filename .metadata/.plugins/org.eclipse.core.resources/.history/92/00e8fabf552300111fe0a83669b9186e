package logical;

public class HTD {
	public static void main(String[] args) {
		
		
		String num = "9B";
		int sum = 0;
		int p=0;
		for(int i=num.length()-1;i>=0;i--)
		{
			Character ch = num.charAt(i);
			
			if(Character.isAlphabetic(ch))
			{
				int k = ch;
				sum+=(k*(Math.pow(16, p)));
			}
			else
			{
				int c = Integer.parseInt(ch.toString());
				sum+=(c*(Math.pow(16, p)));
			}
			
			p+=1;
			
			
		}
		
		
		System.out.println(sum);
	}
}
